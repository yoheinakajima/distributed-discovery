{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "corruptions"],
  "properties": {
    "schema_version": {"const": 1},
    "corruptions": {
      "type": "array",
      "minItems": 12,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["id", "object", "mutation", "expected_invariant", "verifier", "error_class", "scientific_meaning"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "pattern": "^DR-COR-[0-9]{2}$"},
          "object": {"type": "string", "minLength": 1},
          "mutation": {"type": "string", "minLength": 1},
          "expected_invariant": {"type": "string", "minLength": 1},
          "verifier": {"type": "string", "minLength": 1},
          "error_class": {"type": "string", "minLength": 1},
          "scientific_meaning": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "additionalProperties": false
}

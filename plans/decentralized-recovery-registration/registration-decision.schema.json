{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "date", "starting_main", "issue", "branch", "pull_request", "decision", "study_id_allocated", "study_id", "working_title", "central_question", "surviving_statement", "closest_classical_reduction", "information_conditioned_content", "centralized_comparator", "private_comparator", "simultaneous_scope", "sequential_scope", "literature_boundary", "state_space_summary", "runtime_cap", "memory_cap", "primary_method", "independent_method", "corruptions_registered", "stop_condition", "next_program_if_stopped", "exact_next_command", "exact_next_file", "authorized_actions", "prohibited_actions"],
  "properties": {
    "schema_version": {"const": 1},
    "date": {"type": "string"},
    "starting_main": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "issue": {"type": "integer"},
    "branch": {"const": "research/decentralized-recovery-registration"},
    "pull_request": {"type": "integer"},
    "decision": {"enum": ["proceed-to-study-registration", "stop-classical-overlap", "stop-no-falsifiable-distinction", "stop-resource-boundary", "stop-independent-verification-boundary"]},
    "study_id_allocated": {"type": "boolean"},
    "study_id": {"type": ["string", "null"]},
    "working_title": {"type": "string"},
    "central_question": {"type": "string"},
    "surviving_statement": {"type": ["string", "null"]},
    "closest_classical_reduction": {"type": "string"},
    "information_conditioned_content": {"type": "string"},
    "centralized_comparator": {"type": "string"},
    "private_comparator": {"type": "string"},
    "simultaneous_scope": {"type": "string"},
    "sequential_scope": {"type": "string"},
    "literature_boundary": {"type": "string"},
    "state_space_summary": {"type": "string"},
    "runtime_cap": {"type": "string"},
    "memory_cap": {"type": "string"},
    "primary_method": {"type": "string"},
    "independent_method": {"type": "string"},
    "corruptions_registered": {"type": "integer", "minimum": 12},
    "stop_condition": {"type": "string"},
    "next_program_if_stopped": {"type": ["string", "null"]},
    "exact_next_command": {"type": "string"},
    "exact_next_file": {"type": "string"},
    "authorized_actions": {"type": "array", "items": {"type": "string"}},
    "prohibited_actions": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}

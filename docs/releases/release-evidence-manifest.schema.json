{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Distributed Discovery release evidence manifest",
  "type": "object",
  "required": [
    "schema_version", "manifest_kind", "release_status", "compendium_version",
    "candidate_tag", "tag", "source_revision", "github_release_url",
    "version_doi", "concept_doi", "generated_utc", "content_registry",
    "inventory", "artifacts", "paper_bundle", "release_assets", "safety"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "manifest_kind": {"enum": ["example", "dry-run", "release"]},
    "release_status": {"enum": ["template-only", "dry-run-only", "authorized-assets-only"]},
    "compendium_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "candidate_tag": {"type": "string", "pattern": "^dd-compendium-v[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "tag": {"type": ["string", "null"], "pattern": "^dd-compendium-v[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "source_revision": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "github_release_url": {"type": ["string", "null"], "format": "uri"},
    "version_doi": {"type": ["string", "null"]},
    "concept_doi": {"type": ["string", "null"]},
    "generated_utc": {"type": ["string", "null"], "format": "date-time"},
    "content_registry": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"const": "docs/releases/compendium-v0.1.0-content.yml"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "inventory": {
      "type": "object",
      "required": ["claims", "maximum_claim_id", "studies", "maximum_study_id", "manifests", "passing_manifests"],
      "properties": {
        "claims": {"type": "integer", "minimum": 0},
        "maximum_claim_id": {"type": ["string", "null"], "pattern": "^DD-C-[0-9]{4}$"},
        "studies": {"type": "integer", "minimum": 0},
        "maximum_study_id": {"type": ["string", "null"], "pattern": "^DD-[0-9]{3}$"},
        "manifests": {"type": "integer", "minimum": 0},
        "passing_manifests": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["paper_id", "pdf_path", "pdf_sha256", "page_count", "source_bundle", "source_sha256"],
        "properties": {
          "paper_id": {"type": "string"},
          "pdf_path": {"type": "string"},
          "pdf_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "page_count": {"type": "integer", "minimum": 1},
          "source_bundle": {"type": "string"},
          "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        },
        "additionalProperties": false
      }
    },
    "paper_bundle": {
      "type": ["object", "null"],
      "required": ["filename", "sha256", "inventory_member", "archive_members", "papers", "pages"],
      "properties": {
        "filename": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "inventory_member": {"type": "string"},
        "archive_members": {"type": "integer", "minimum": 1},
        "papers": {"const": 7},
        "pages": {"const": 119}
      },
      "additionalProperties": false
    },
    "release_assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["filename", "sha256", "bytes"],
        "properties": {
          "filename": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": false
      }
    },
    "safety": {
      "type": "object",
      "required": ["tracked_files_only", "symlinks", "external_mutations", "private_material", "credentials", "host_paths"],
      "properties": {
        "tracked_files_only": {"const": true},
        "symlinks": {"const": 0},
        "external_mutations": {"const": 0},
        "private_material": {"const": 0},
        "credentials": {"const": 0},
        "host_paths": {"const": 0}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

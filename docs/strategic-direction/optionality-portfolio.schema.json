{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "principle", "rejected_principle", "first_option_to_exercise", "simultaneous_execution_branches", "stopped_options_preserved", "measurement_boundary", "options"],
  "properties": {
    "schema_version": {"const": 1},
    "principle": {"const": "shared trunk, low-cost option creation, staged exercise"},
    "rejected_principle": {"const": "ambition rises at no additional cost"},
    "first_option_to_exercise": {"const": "WS-1"},
    "simultaneous_execution_branches": {"const": false},
    "stopped_options_preserved": {"const": true},
    "measurement_boundary": {
      "type": "object",
      "required": ["scientific_score", "measured_expected_value", "measured_impact"],
      "properties": {
        "scientific_score": {"const": false},
        "measured_expected_value": {"const": false},
        "measured_impact": {"const": false}
      },
      "additionalProperties": false
    },
    "options": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "type": "object",
        "required": ["id", "label", "status", "readiness", "residual_value", "decay_rate", "estimated_expiry_horizon", "option_trigger", "first_irreversible_spend", "kill_or_defer_condition", "evidence_required", "ai_native_validation_required", "dependencies", "currently_authorized_actions", "prohibited_actions", "public_visibility", "next_review_date"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string", "minLength": 1},
          "status": {"enum": ["registered-offline-execution-gated", "registration-next", "design-only", "gated-candidate", "architecture-only", "draft-standard-option", "unregistered-theorem-gate", "preserved-deferred"]},
          "readiness": {"enum": ["offline-implementation-next", "registration-ready", "architecture-ready", "prospectus-ready", "question-only", "deferred"]},
          "residual_value": {"enum": ["high-if-exercised-soon", "high-but-gated", "medium-and-durable", "uncertain-until-gate", "preserved"]},
          "decay_rate": {"enum": ["fast", "moderate", "slow", "unknown"]},
          "estimated_expiry_horizon": {"type": "string", "minLength": 1},
          "option_trigger": {"type": "string", "minLength": 1},
          "first_irreversible_spend": {"type": "string", "minLength": 1},
          "kill_or_defer_condition": {"type": "string", "minLength": 1},
          "evidence_required": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "ai_native_validation_required": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "currently_authorized_actions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "prohibited_actions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "public_visibility": {"enum": ["public-gate", "public-design-boundary", "internal-gated-candidate", "internal-only"]},
          "next_review_date": {"type": "string", "format": "date"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

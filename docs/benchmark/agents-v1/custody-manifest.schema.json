{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiscoveryBench Agents v1 custody manifest",
  "type": "object",
  "required": ["schema_version", "public_test_only", "benchmark_version", "generator_version", "artifact_status", "commitments", "encryption"],
  "properties": {
    "schema_version": {"const": 1},
    "public_test_only": {"type": "boolean"},
    "benchmark_version": {"const": "agents-v1"},
    "generator_version": {"const": "agents-task-generator-v1"},
    "artifact_status": {"enum": ["public-toy-vector", "future-sealed-holdout"]},
    "commitments": {
      "type": "object",
      "required": ["domain_separator", "seed_sha256", "instance_sha256"],
      "properties": {
        "seed_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "instance_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "encryption": {
      "type": "object",
      "required": ["status", "allowed_algorithms"],
      "properties": {
        "status": {"enum": ["not-used-public-test", "future-encrypted"]},
        "allowed_algorithms": {
          "type": "array",
          "items": {"enum": ["XChaCha20-Poly1305", "AES-256-GCM"]},
          "minItems": 1
        }
      }
    }
  },
  "additionalProperties": true
}

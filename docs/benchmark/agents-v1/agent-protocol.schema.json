    "agent_identity": {"type": "object"},
    "communication": {"type": "object"},
    "memory": {"type": "object"},
    "context": {"type": "object"},
    "tools": {"type": "object"},
    "sampling": {"type": "object"},
    "action_output": {"type": "object"},
    "trace_boundary": {"type": "object"}
  },
  "additionalProperties": true
}

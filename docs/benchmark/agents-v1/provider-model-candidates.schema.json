{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiscoveryBench Agents v1 provider/model candidate registry",
  "type": "object",
  "required": ["schema_version", "status", "access_date", "execution_authorized", "selection_policy", "candidates"],
  "properties": {
    "schema_version": {"const": 1},
    "status": {"const": "audited-not-selected"},
    "access_date": {"type": "string", "format": "date"},
    "execution_authorized": {"const": false},
    "selection_policy": {
      "type": "object",
      "required": ["minimum_cloud_families", "local_open_candidate_required", "moving_alias_allowed", "exact_snapshot_required"],
      "properties": {
        "minimum_cloud_families": {"type": "integer", "minimum": 2},
        "local_open_candidate_required": {"const": true},
        "moving_alias_allowed": {"const": false},
        "exact_snapshot_required": {"const": true}
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "candidate_id", "provider", "deployment", "exact_model_identifier",
          "snapshot_status", "moving_alias_status", "context_window_tokens",
          "max_output_tokens", "structured_output", "tool_control",
          "sampling_controls", "seed_support", "retry_error_semantics",
          "trace_fields", "pricing", "rate_limit_uncertainty", "terms_or_license",
          "data_retention", "reproducibility_limitation", "execution_eligibility",
          "citations"
        ],
        "properties": {
          "candidate_id": {"type": "string", "minLength": 3},
          "provider": {"type": "string", "minLength": 2},
          "deployment": {"enum": ["cloud-api", "local-open-weights"]},
          "exact_model_identifier": {"type": "string", "minLength": 3},
          "context_window_tokens": {"type": "integer", "minimum": 1},
          "max_output_tokens": {"type": "integer", "minimum": 1},
          "pricing": {
            "type": "object",
            "required": ["date", "currency", "unit", "input", "output", "cached_input", "batch_discount"]
          },
          "execution_eligibility": {
            "enum": [
              "eligible-for-future-selection",
              "blocked-pending-snapshot-and-retention-verification",
              "eligible-after-hardware-and-weight-hash-gate"
            ]
          },
          "citations": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "pattern": "^https://"}
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "authority", "retrievability_monitoring", "entries"],
  "properties": {
    "schema_version": {"const": 1},
    "authority": {"const": "editorial translation only; claims and studies remain scientific authority"},
    "retrievability_monitoring": {
      "type": "object",
      "required": ["search_rank", "ai_referrers", "predeclared_queries", "citation_rank", "semantic_visibility", "discoverybench_contamination_only"],
      "properties": {
        "search_rank": {"const": false},
        "ai_referrers": {"const": false},
        "predeclared_queries": {"const": false},
        "citation_rank": {"const": false},
        "semantic_visibility": {"const": false},
        "discoverybench_contamination_only": {"const": true}
      },
      "additionalProperties": false
    },
    "entries": {
      "type": "array",
      "minItems": 14,
      "items": {
        "type": "object",
        "required": ["object_id", "canonical_label", "canonical_definition", "formulations"],
        "properties": {
          "object_id": {"type": "string", "pattern": "^TR-[0-9]{3}$"},
          "canonical_label": {"type": "string", "minLength": 2},
          "canonical_definition": {"type": "string", "minLength": 10},
          "formulations": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": ["community", "relation_type", "community_formulation", "standard_literature_terms", "canonical_object", "claim_ids", "study_ids", "paper_owners", "literature_coverage", "mandatory_qualifier", "prohibited_phrasing", "approved_public_surfaces"],
              "properties": {
                "community": {"enum": ["or-ms", "economics-agt", "multi-agent-ai", "practitioner"]},
                "relation_type": {"enum": ["exact-equivalent", "standard-literature-neighbor", "approximate-restatement", "analogy", "practitioner-formulation"]},
                "community_formulation": {"type": "string", "minLength": 2},
                "standard_literature_terms": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
                "canonical_object": {"type": "string", "pattern": "^TR-[0-9]{3}$"},
                "claim_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^DD-C-[0-9]{4}$"}, "uniqueItems": true},
                "study_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^DD-[0-9]{3}[A-Z]?$"}, "uniqueItems": true},
                "paper_owners": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
                "literature_coverage": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^LIT-[0-9]{3}$"}, "uniqueItems": true},
                "mandatory_qualifier": {"type": "string", "minLength": 5},
                "prohibited_phrasing": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
                "approved_public_surfaces": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

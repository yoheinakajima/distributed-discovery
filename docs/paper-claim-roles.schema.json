{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "authority", "role_vocabulary", "claims"],
  "properties": {
    "schema_version": {"const": 1},
    "authority": {"const": "editorial roles only; claims and studies remain scientific authority"},
    "role_vocabulary": {
      "const": ["primary", "supporting", "background", "counterboundary", "historical-source", "absorbed-from-superseded-paper"]
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim_id", "study_id", "paper_roles"],
        "properties": {
          "claim_id": {"type": "string", "pattern": "^DD-C-[0-9]{4}$"},
          "study_id": {"type": "string", "pattern": "^DD-[0-9]{3}[A-Z]?$"},
          "paper_roles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["paper_id", "role"],
              "properties": {
                "paper_id": {"type": "string"},
                "role": {"enum": ["primary", "supporting", "background", "counterboundary", "historical-source", "absorbed-from-superseded-paper"]}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Distributed Discovery program-memory registry",
  "type": "object",
  "required": ["schema_version", "authority", "records"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "authority": {"const": "routing-only-not-scientific-evidence"},
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "idea_id", "title", "status", "capture_classification",
          "visibility", "source_type", "captured_date", "proposition",
          "why_it_matters", "canonical_destination", "dependencies",
          "promotion_trigger", "permitted_stops", "not_a_result_boundaries",
          "supersedes", "superseded_by", "review_after", "owner_decision",
          "last_reviewed"
        ],
        "properties": {
          "idea_id": {"type": "string", "pattern": "^PM-[0-9]{4}$"},
          "title": {"type": "string", "minLength": 3},
          "status": {
            "enum": [
              "captured-unreviewed", "candidate", "owner-adopted", "routed",
              "evidence-dependent", "deferred", "rejected", "superseded",
              "implemented", "closed-by-overlap", "closed-by-null"
            ]
          },
          "capture_classification": {
            "enum": [
              "capture-now", "queue-after-active-pr", "evidence-dependent",
              "already-canonical", "superseded", "do-not-canonicalize"
            ]
          },
          "visibility": {"enum": ["public", "internal", "restricted-reference-only"]},
          "source_type": {
            "enum": ["owner-decision", "repository-reconciliation", "external-policy-observation"]
          },
          "captured_date": {"type": "string", "format": "date"},
          "proposition": {"type": "string", "minLength": 8},
          "why_it_matters": {"type": "string", "minLength": 8},
          "canonical_destination": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "path"],
            "properties": {
              "type": {
                "enum": [
                  "policy", "decision-record", "ADR", "ExecPlan", "roadmap",
                  "lifecycle-registry", "release-record", "claim-or-study-link"
                ]
              },
              "path": {"type": "string", "minLength": 3}
            }
          },
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "promotion_trigger": {"type": ["string", "null"]},
          "permitted_stops": {
            "type": "array",
            "minItems": 1,
            "items": {"enum": ["implemented", "deferred", "rejected", "superseded", "closed-by-overlap", "closed-by-null"]}
          },
          "not_a_result_boundaries": {
            "type": "array", "minItems": 1, "items": {"type": "string"}
          },
          "supersedes": {"type": "array", "items": {"type": "string"}},
          "superseded_by": {"type": ["string", "null"]},
          "review_after": {"type": ["string", "null"]},
          "owner_decision": {
            "enum": ["adopted", "already-canonical", "deferred", "rejected", "superseded"]
          },
          "last_reviewed": {"type": "string", "format": "date"}
        }
      }
    }
  }
}

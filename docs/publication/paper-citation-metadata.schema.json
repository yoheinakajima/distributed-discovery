{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "scope", "papers", "examples"],
  "properties": {
    "schema_version": {"const": 1},
    "scope": {"const": "per-paper citation metadata; root CITATION.cff remains compendium-level"},
    "papers": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": [
          "paper_id", "title", "authors", "status", "version", "arxiv_id",
          "doi", "recommended_citation", "source_bundle", "pdf_sha256",
          "claim_ownership"
        ],
        "properties": {
          "paper_id": {"type": "string"},
          "title": {"type": "string", "minLength": 1},
          "authors": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "status": {"enum": ["working-paper", "research-note", "synthesis-note"]},
          "version": {"type": "string", "minLength": 1},
          "arxiv_id": {"type": ["string", "null"]},
          "doi": {"type": ["string", "null"]},
          "recommended_citation": {"type": "string", "minLength": 1},
          "source_bundle": {"type": "string", "minLength": 1},
          "pdf_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "claim_ownership": {
            "type": "array",
            "items": {"type": "string", "pattern": "^DD-C-[0-9]{4}$"},
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "examples": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["purpose", "paper_id", "arxiv_id", "doi", "claim_id", "run_id", "artifact_sha256"],
        "properties": {
          "purpose": {"type": "string"},
          "paper_id": {"type": "string"},
          "arxiv_id": {"type": ["string", "null"]},
          "doi": {"type": ["string", "null"]},
          "claim_id": {"type": ["string", "null"], "pattern": "^DD-C-[0-9]{4}$"},
          "run_id": {"type": ["string", "null"]},
          "artifact_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

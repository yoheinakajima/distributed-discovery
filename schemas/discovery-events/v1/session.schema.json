{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://distributed-discovery.org/schemas/discovery-events/v1/session.schema.json",
  "title": "Synthetic discovery session",
  "type": "object",
  "additionalProperties": false,
  "required": ["session_id", "protocol", "target_id", "synthetic", "event_count"],
  "properties": {
    "session_id": {"type": "string", "minLength": 1},
    "protocol": {"enum": ["private", "consensus", "assigned"]},
    "target_id": {"type": "string", "minLength": 1},
    "synthetic": {"const": true},
    "event_count": {"type": "integer", "minimum": 1}
  }
}
